{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "e2e/specs/*.spec.ts",
    "e2e/global-setup.ts",
    "e2e/global-teardown.ts",
    "playwright.config.ts"
  ]
}
