# Flask
FLASK_APP=run.py
FLASK_ENV=development

# Database — use 'db' as host when running inside Docker
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/movie-night

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# Clerk
CLERK_SECRET_KEY=CHANGE_ME
CLERK_WEBHOOK_SECRET=CHANGE_ME
# e.g. https://<frontend_url>/.well-known/jwks.json
CLERK_JWKS_URL=CHANGE_ME

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173
